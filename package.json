{
  "name": "svelte-multiselect",
  "description": "Svelte multi-select component",
  "author": "Janosh Riebesell <janosh.riebesell@gmail.com>",
  "homepage": "https://janosh.github.io/svelte-multiselect",
  "repository": "https://github.com/janosh/svelte-multiselect",
  "license": "MIT",
  "version": "11.6.3",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest --run && node node_modules/@playwright/test/cli.js test",
    "package": "svelte-package && find dist -name '*.js' -o -name '*.d.ts' | xargs sed -i '' -E \"s/(\\.\\.?\\/[^'\\\"]*)\\.ts(['\\\"])/\\1.js\\2/g\"",
    "prepublishOnly": "pnpm package"
  },
  "svelte": "./dist/index.js",
  "bugs": "https://github.com/janosh/svelte-multiselect/issues",
  "peerDependencies": {
    "@wooorm/starry-night": "^3.0.0",
    "acorn": "^8.0.0",
    "svelte": "^5.48.0"
  },
  "peerDependenciesMeta": {
    "@wooorm/starry-night": {
      "optional": true
    },
    "acorn": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/package": "2.5.7",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@wooorm/starry-night": "^3.9.0",
    "acorn": "^8.16.0",
    "eslint": "^10.0.3",
    "eslint-plugin-svelte": "^3.15.2",
    "happy-dom": "^20.8.4",
    "mdsvex": "^0.12.7",
    "svelte": "^5.53.12",
    "svelte-toc": "^0.6.3",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "overrides": {
      "svelte": "$svelte"
    }
  },
  "keywords": [
    "svelte",
    "multi-select",
    "single-select",
    "form",
    "input"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./MultiSelect.svelte": {
      "types": "./dist/MultiSelect.svelte.d.ts",
      "svelte": "./dist/MultiSelect.svelte",
      "default": "./dist/MultiSelect.svelte"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./attachments": {
      "types": "./dist/attachments.d.ts",
      "default": "./dist/attachments.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "default": "./dist/utils.js"
    },
    "./heading-anchors": {
      "types": "./dist/heading-anchors.d.ts",
      "default": "./dist/heading-anchors.js"
    },
    "./live-examples": {
      "types": "./dist/live-examples/index.d.ts",
      "default": "./dist/live-examples/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ]
}
